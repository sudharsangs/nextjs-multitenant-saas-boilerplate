erDiagram
    Users ||--o{ UserRoles : has
    Users ||--o{ AuditLogs : generates
    Roles ||--o{ UserRoles : contains
    Roles ||--o{ RolePermissions : has
    Permissions ||--o{ RolePermissions : "assigned to"
    Users ||--o{ Orders : creates
    Orders ||--o{ Invoices : generates
    Invoices ||--o{ InvoiceItems : contains
    Customers ||--o{ Orders : places
    Customers ||--o{ Addresses : has
    Customers ||--o{ PaymentMethods : has
    Orders ||--|{ OrderItems : contains
    Orders ||--o{ Shipments : has
    Orders ||--|| PaymentTransactions : has
    Orders ||--o{ ReturnOrders : has
    Products ||--o{ OrderItems : "ordered in"
    Products ||--o{ InventoryItems : "tracked in"
    Products ||--|| ProductCategories : "belongs to"
    Warehouses ||--o{ InventoryItems : stores
    Suppliers ||--o{ PurchaseOrders : receives
    PurchaseOrders ||--|{ PurchaseOrderItems : contains
    Products ||--o{ PurchaseOrderItems : "ordered in"

    Users {
        int user_id PK
        string username
        string email
        string password_hash
        string salt
        boolean is_active
        datetime last_login
        datetime created_at
        datetime updated_at
        int created_by FK
    }

    Roles {
        int role_id PK
        string name
        string description
        boolean is_active
    }

    Permissions {
        int permission_id PK
        string name
        string description
        string resource
        string action
    }

    UserRoles {
        int user_role_id PK
        int user_id FK
        int role_id FK
        datetime assigned_at
        int assigned_by FK
    }

    RolePermissions {
        int role_permission_id PK
        int role_id FK
        int permission_id FK
    }

    AuditLogs {
        int audit_id PK
        int user_id FK
        string action
        string entity_type
        int entity_id
        json old_values
        json new_values
        datetime timestamp
        string ip_address
    }

    Invoices {
        int invoice_id PK
        int order_id FK
        string invoice_number
        datetime invoice_date
        datetime due_date
        decimal total_amount
        decimal tax_amount
        string status
        string payment_status
        int created_by FK
    }

    InvoiceItems {
        int invoice_item_id PK
        int invoice_id FK
        int product_id FK
        int quantity
        decimal unit_price
        decimal discount
        decimal tax_rate
        decimal line_total
    }

    Customers {
        int customer_id PK
        string name
        string email
        string phone
        decimal credit_limit
        datetime created_at
        boolean is_active
        int created_by FK
        int updated_by FK
    }

    Orders {
        int order_id PK
        int customer_id FK
        int address_id FK
        int user_id FK
        decimal total_amount
        string status
        datetime order_date
        string payment_status
        decimal tax_amount
        string currency
        int created_by FK
        int updated_by FK
    }

    OrderItems {
        int order_item_id PK
        int order_id FK
        int product_id FK
        int quantity
        decimal unit_price
        decimal discount
        string status
    }

    Products {
        int product_id PK
        int category_id FK
        string name
        string sku
        decimal base_price
        string description
        boolean active
        decimal min_stock_level
        int created_by FK
        int updated_by FK
    }

    InventoryItems {
        int inventory_id PK
        int product_id FK
        int warehouse_id FK
        int quantity
        string lot_number
        date expiry_date
        string location
        int updated_by FK
    }

    Warehouses {
        int warehouse_id PK
        string name
        string address
        string contact_info
        boolean is_active
    }

    Suppliers {
        int supplier_id PK
        string name
        string contact_person
        string email
        string phone
        string payment_terms
        int created_by FK
        int updated_by FK
    }

    PurchaseOrders {
        int po_id PK
        int supplier_id FK
        datetime order_date
        string status
        decimal total_amount
        datetime expected_delivery
        int created_by FK
        int approved_by FK
    }

    PurchaseOrderItems {
        int po_item_id PK
        int po_id FK
        int product_id FK
        int quantity
        decimal unit_cost
    }

    Shipments {
        int shipment_id PK
        int order_id FK
        string tracking_number
        string carrier
        datetime ship_date
        string status
        decimal shipping_cost
        int created_by FK
    }

    ReturnOrders {
        int return_id PK
        int order_id FK
        string rma_number
        string reason
        string status
        datetime created_at
        decimal refund_amount
        int approved_by FK
    }

    PaymentTransactions {
        int transaction_id PK
        int order_id FK
        decimal amount
        string payment_method
        datetime transaction_date
        string status
    }

    PaymentMethods {
        int payment_method_id PK
        int customer_id FK
        string type
        string details
        boolean is_default
        datetime expiry_date
    }

    Addresses {
        int address_id PK
        int customer_id FK
        string street
        string city
        string state
        string country
        string postal_code
        boolean is_default
    }

    ProductCategories {
        int category_id PK
        string name
        string description
        boolean active
    }
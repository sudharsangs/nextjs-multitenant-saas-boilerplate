graph TD
    %% Authentication Flow
    A[User] -->|Login| B[Authentication]
    B -->|Success| C[Dashboard]
    B -->|Failure| A

    %% Main Navigation
    C -->|View| D[Orders]
    C -->|Manage| E[Products]
    C -->|Manage| F[Customers]
    C -->|Manage| G[Inventory]
    C -->|Manage| H[Purchase Orders]
    C -->|Manage| I[Reports]

    %% Order Management Flow
    D -->|Create| J[New Order]
    D -->|View| K[Order Details]
    K -->|Process| L[Order Processing]
    L -->|Ship| M[Shipment]
    L -->|Invoice| N[Invoice]
    L -->|Return| O[Return Order]

    %% Product Management Flow
    E -->|Add| P[New Product]
    E -->|Edit| Q[Product Details]
    E -->|Categorize| R[Product Categories]

    %% Customer Management Flow
    F -->|Add| S[New Customer]
    F -->|Edit| T[Customer Details]
    T -->|Manage| U[Addresses]
    T -->|Manage| V[Payment Methods]

    %% Inventory Management Flow
    G -->|View| W[Stock Levels]
    G -->|Adjust| X[Stock Adjustment]
    G -->|Transfer| Y[Warehouse Transfer]

    %% Purchase Order Flow
    H -->|Create| Z[New PO]
    H -->|View| AA[PO Details]
    AA -->|Receive| AB[Receive Goods]
    AA -->|Approve| AC[Approve PO]

    %% User Management
    C -->|Admin| AD[User Management]
    AD -->|Manage| AE[Users]
    AD -->|Manage| AF[Roles]
    AD -->|Manage| AG[Permissions]

    %% Styling
    classDef default fill:#f9f,stroke:#333,stroke-width:2px;
    classDef process fill:#bbf,stroke:#333,stroke-width:2px;
    classDef decision fill:#dfd,stroke:#333,stroke-width:2px;
    
    class A,B,C default;
    class D,E,F,G,H,I process;
    class J,K,L,M,N,O,P,Q,R,S,T,U,V,W,X,Y,Z,AA,AB,AC,AD,AE,AF,AG decision; 